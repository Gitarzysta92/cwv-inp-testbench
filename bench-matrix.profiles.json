{
  "$schema": "./bench-matrix.schema.json",
  "outputDir": "bench-results",
  "runs": 5,
  "aggregate": {
    "percentiles": [50, 75, 95],
    "trimExtremesPercent": 10,
    "acceptableDeltaMs": 40,
    "metrics": ["eventTimingMaxMs", "wallClockMs", "searchTypingWallMs", "inpMs"]
  },
  "configurations": [
    {
      "id": "desktop-cold",
      "label": "Desktop 1280x720, cold storage/cache policy, headless Chromium",
      "env": {
        "BENCH_WARMUP": "cold",
        "BENCH_VIEWPORT_WIDTH": "1280",
        "BENCH_VIEWPORT_HEIGHT": "720"
      }
    },
    {
      "id": "desktop-warm-assets",
      "label": "Desktop 1280x720, assets prewarmed, headless Chromium",
      "env": {
        "BENCH_WARMUP": "warm_assets",
        "BENCH_VIEWPORT_WIDTH": "1280",
        "BENCH_VIEWPORT_HEIGHT": "720"
      }
    },
    {
      "id": "desktop-warm-session",
      "label": "Desktop 1280x720, warm session state, headless Chromium",
      "env": {
        "BENCH_WARMUP": "warm_session",
        "BENCH_VIEWPORT_WIDTH": "1280",
        "BENCH_VIEWPORT_HEIGHT": "720"
      }
    },
    {
      "id": "mobile-cold",
      "label": "Mobile-like 390x844, cold storage/cache policy, headless Chromium",
      "env": {
        "BENCH_WARMUP": "cold",
        "BENCH_VIEWPORT_WIDTH": "390",
        "BENCH_VIEWPORT_HEIGHT": "844"
      }
    },
    {
      "id": "mobile-warm-assets",
      "label": "Mobile-like 390x844, assets prewarmed, headless Chromium",
      "env": {
        "BENCH_WARMUP": "warm_assets",
        "BENCH_VIEWPORT_WIDTH": "390",
        "BENCH_VIEWPORT_HEIGHT": "844"
      }
    },
    {
      "id": "desktop-targeted-slowdown",
      "label": "Desktop 1280x720, cold policy, targeted interaction slowdown",
      "env": {
        "BENCH_WARMUP": "cold",
        "BENCH_VIEWPORT_WIDTH": "1280",
        "BENCH_VIEWPORT_HEIGHT": "720",
        "BENCH_SLOW_CLICK_JSON": "{\"filter-electronics\":100,\"filter-1\":40,\"filter-2\":40,\"filter-3\":40,\"filter-4\":80,\"gallery-thumb-3\":100,\"add-to-cart\":80,\"cart-plus\":70,\"add-first-product\":50,\"open-cart\":30}",
        "BENCH_SLOW_KEYDOWN_JSON": "{\"search-input\":12}"
      }
    },
    {
      "id": "mobile-targeted-slowdown",
      "label": "Mobile-like 390x844, cold policy, targeted interaction slowdown",
      "env": {
        "BENCH_WARMUP": "cold",
        "BENCH_VIEWPORT_WIDTH": "390",
        "BENCH_VIEWPORT_HEIGHT": "844",
        "BENCH_SLOW_CLICK_JSON": "{\"filter-electronics\":100,\"filter-1\":40,\"filter-2\":40,\"filter-3\":40,\"filter-4\":80,\"gallery-thumb-3\":100,\"add-to-cart\":80,\"cart-plus\":70,\"add-first-product\":50,\"open-cart\":30}",
        "BENCH_SLOW_KEYDOWN_JSON": "{\"search-input\":12}"
      }
    }
  ],
  "playwrightArgs": ["e2e/scenarios-a-d.spec.ts"]
}
