{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bench matrix",
  "type": "object",
  "required": ["outputDir", "runs", "configurations"],
  "properties": {
    "outputDir": { "type": "string" },
    "runs": { "type": "integer", "minimum": 1 },
    "aggregate": {
      "type": "object",
      "properties": {
        "percentiles": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 99 }
        },
        "trimExtremesPercent": { "type": "number", "minimum": 0, "maximum": 45 },
        "metrics": { "type": "array", "items": { "type": "string" } },
        "acceptableDeltaMs": { "type": "number", "minimum": 0 }
      }
    },
    "configurations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "env": { "type": "object", "additionalProperties": { "type": "string" } }
        }
      }
    },
    "playwrightArgs": { "type": "array", "items": { "type": "string" } }
  }
}
