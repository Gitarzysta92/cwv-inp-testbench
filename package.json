{
  "name": "web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "bench": "node scripts/bench-orchestrator.mjs",
    "bench:fast": "node scripts/bench-orchestrator.mjs --config ./bench-matrix.fast.json",
    "bench:compare": "node scripts/bench-orchestrator.mjs --config ./bench-matrix.compare.json",
    "bench:profiles": "node scripts/bench-orchestrator.mjs --config ./bench-matrix.profiles.json",
    "bench:aggregate": "node scripts/bench-aggregate.mjs",
    "bench:v2": "tsx v2/src/orchestrator/main.ts",
    "bench:v2:runtime-api": "tsx v2/src/runtime/api/server.ts",
    "bench:v2:clients-api": "tsx v2/src/clients/api/server.ts",
    "bench:v2:appliance": "v2/scripts/start-browser-appliance.sh",
    "bench:v2:docker": "tsx v2/src/orchestrator/main.ts --docker manage",
    "bench:v2:docker:runtime": "docker compose -f v2/docker/compose.runtime.yaml up -d --build",
    "bench:v2:docker:full": "docker compose -f v2/docker/compose.yaml up --build --abort-on-container-exit",
    "bench:v2:docker:live": "docker compose -f v2/docker/compose.live.yaml up --build --abort-on-container-exit",
    "bench:v2:docker:build": "docker compose -f v2/docker/compose.runtime.yaml build",
    "lh": "node scripts/lighthouse-run.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "web-vitals": "^5.2.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.15",
    "@angular/cli": "^19.2.15",
    "@angular/compiler-cli": "^19.2.0",
    "@playwright/test": "^1.59.1",
    "@types/jasmine": "~5.1.0",
    "chrome-launcher": "^1.2.1",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lighthouse": "^12.8.2",
    "serve": "^14.2.6",
    "tsx": "^4.22.3",
    "typescript": "~5.7.2"
  }
}
